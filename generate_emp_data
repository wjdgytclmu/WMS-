UPDATE employees SET emp_status = '离职'
WHERE emp_id IN (
    SELECT emp_id FROM (SELECT emp_id FROM employees ORDER BY RAND() LIMIT 1000) t
);

CREATE TRIGGER trg_attendance_after_insert AFTER INSERT ON attendance_records
FOR EACH ROW BEGIN CALL sp_recalc_attendance_items(NEW.emp_id, DATE_FORMAT(NEW.att_date, '%Y-%m')); END;

CREATE TRIGGER trg_attendance_after_update AFTER UPDATE ON attendance_records
FOR EACH ROW BEGIN
    CALL sp_recalc_attendance_items(NEW.emp_id, DATE_FORMAT(NEW.att_date, '%Y-%m'));
    IF OLD.att_date != NEW.att_date THEN
        CALL sp_recalc_attendance_items(OLD.emp_id, DATE_FORMAT(OLD.att_date, '%Y-%m'));
    END IF;
END;

CREATE TRIGGER trg_attendance_after_delete AFTER DELETE ON attendance_records
FOR EACH ROW BEGIN CALL sp_recalc_attendance_items(OLD.emp_id, DATE_FORMAT(OLD.att_date, '%Y-%m')); END;

