-- ============================================================================
-- 题目 (7)："计算"存储过程 → 审核 → 锁定 → 冲销修正完整流程
-- 要求：设计存储过程完成"计算"功能，生成当月工资发放表
-- ============================================================================
SELECT '--- 题目 (7) 计算→审核→锁定→冲销修正 ---' AS '';

-- ① 财务点击"计算"：汇总明细到总表，状态 = "待审核"
CALL sp_calculate_payroll('2026-07');

-- ② 按员工查询工资发放表（前 10 条）
SELECT * FROM v_payroll_company WHERE salary_month = '2026-07' LIMIT 10;

-- ③ 按部门查询：研发部及下属分部的工资
SELECT * FROM v_payroll_company
WHERE dept_name IN ('研发部','后端研发分部','前端研发分部') AND salary_month = '2026-07'
ORDER BY dept_name, emp_name LIMIT 15;

-- ④ 全公司汇总：人数、应发总额、应扣总额、实发总额
SELECT salary_month, COUNT(*) AS 人数,
       SUM(total_income) AS 应发总额, SUM(total_deduct) AS 应扣总额, SUM(real_salary) AS 实发总额
FROM v_payroll_company WHERE salary_month = '2026-07' GROUP BY salary_month;

-- ⑤ 审核无误，锁定为"已发放"
CALL sp_audit_payroll('2026-07');

-- ⑥ 核查发现错误：员工 5 的项目补贴多发了 500 元，需要冲销修正
--     第一步：解锁
CALL sp_unlock_payroll('2026-07');
--     第二步：插入冲销记录（负金额抵消原记录，is_overridden=1 标记）
INSERT INTO monthly_salary_details(emp_id, salary_month, cat_id, amount, is_overridden, override_note)
SELECT 5, '2026-07', cat_id, -500, 1, '冲销：项目补贴多计'
FROM salary_categories WHERE cat_name = '项目补贴'
ON DUPLICATE KEY UPDATE
    amount = VALUES(amount),
    is_overridden = VALUES(is_overridden),
    override_note = VALUES(override_note);
--     第三步：重算 → 重新审核锁定
CALL sp_calculate_payroll('2026-07');
CALL sp_audit_payroll('2026-07');

-- ⑦ 验证：员工 5 的项目补贴合计应为 (原始 - 500)
SELECT e.emp_name, sc.cat_name, SUM(msd.amount) AS 合计
FROM monthly_salary_details msd
JOIN employees e ON msd.emp_id = e.emp_id
JOIN salary_categories sc ON msd.cat_id = sc.cat_id
WHERE msd.emp_id = 5 AND msd.salary_month = '2026-07' AND sc.cat_name = '项目补贴'
GROUP BY e.emp_name, sc.cat_name;


