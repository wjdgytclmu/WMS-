-- ============================================================================
-- 工资管理系统（WMS）— 数据库成果演示脚本
-- 用途：逐题目验证项目成果，可在 MySQL 中分段选中运行
-- 前置：已按顺序执行 create_table.sql → create_functions → create_view
--       → create_procedure → create_trigger → create_event → generate_500_emp_data
-- ============================================================================

USE WMS;


-- ############################################################################
-- 第一阶段：初始化当月工资
-- 说明：手动调用存储过程，模拟每月发薪日凌晨定时任务的执行效果
--       sp_init_monthly_salary   → 把系统计算项写入月度工资明细
--       sp_calculate_seniority_salary → 计算工龄工资并写入独立表 + 同步到明细
-- ############################################################################

-- 1.1 初始化 2026 年 7 月工资明细
-- 内部逻辑：复制 6 月基本工资 → 取发薪日前有效的职称/岗位工资 → 考勤项默认填 0
CALL sp_init_monthly_salary('2026-07');

-- 1.2 计算 7 月工龄工资
-- 内部逻辑：匹配当前生效的工龄规则 V3（base=500, add=150/年）
--           按入职日期算工龄年数 → base + 年限×add → 写入 seniority_salary 独立表
--           再从独立表同步到 monthly_salary_details（cat_id=4）
CALL sp_calculate_seniority_salary('2026-07');


-- ############################################################################
-- 第二阶段：模拟考勤变动，验证触发器
-- 说明：考勤表一次 INSERT/UPDATE/DELETE，触发器自动重算当月缺勤扣款和全勤奖励
--       计算规则：请假 100/天 | 迟到早退 50/次 | 旷工 300/天 | 满勤奖 300
-- ############################################################################

-- 2.1 员工 5：新增 1 天请假 → 触发器自动：请假扣款 +100，全勤奖励归 0
INSERT INTO attendance_records(emp_id, att_type, att_date) VALUES (5, '请假', '2026-07-03');

-- 2.2 员工 10：新增 1 天旷工 → 触发器自动：旷工扣款 +300
INSERT INTO attendance_records(emp_id, att_type, att_date) VALUES (10, '旷工', '2026-07-05');

-- 2.3 查询月度工资明细，验证触发器是否正确更新了扣款和全勤奖励
SELECT e.emp_name, sc.cat_name, msd.amount
FROM monthly_salary_details msd
JOIN employees e ON msd.emp_id = e.emp_id
JOIN salary_categories sc ON msd.cat_id = sc.cat_id
WHERE msd.emp_id IN (5, 10) AND msd.salary_month = '2026-07'
  AND sc.cat_name IN ('请假扣款','旷工扣款','全勤奖励');


-- ############################################################################
-- 第三阶段：手动录入工资项
-- 说明：HR 手动修改"手动录入"或"系统计算(可覆盖)"类别的工资金额
--       修改后 is_overridden 标记为 1，override_note 记录原因，便于审计
-- ############################################################################

-- 3.1 员工 2 的项目补贴从随机默认值改为 2000（优秀项目奖励）
CALL sp_upsert_manual_item(2, '2026-07', '项目补贴', 2000.00, '优秀项目奖励');

-- 3.2 员工 2 的个税扣除改为 -800（累计计税调整）
CALL sp_upsert_manual_item(2, '2026-07', '个税扣除', -800.00, '累计计税调整');

-- 3.3 查看员工 2 被手动修改过的工资项，确认覆盖标记和备注已记录
SELECT e.emp_name, sc.cat_name, msd.amount, msd.is_overridden, msd.override_note
FROM monthly_salary_details msd
JOIN employees e ON msd.emp_id = e.emp_id
JOIN salary_categories sc ON msd.cat_id = sc.cat_id
WHERE msd.emp_id = 2 AND msd.salary_month = '2026-07' AND msd.is_overridden = 1;


