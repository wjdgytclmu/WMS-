SELECT COUNT(*) AS 职称变更记录 FROM emp_title_history;
SELECT COUNT(*) AS 岗位变更记录 FROM emp_position_history;
SELECT COUNT(*) AS 考勤记录 FROM attendance_records;
SELECT COUNT(*) AS 月度薪资明细 FROM monthly_salary_details;
SELECT COUNT(*) AS 月度薪资汇总台账 FROM monthly_salary_summary;

















